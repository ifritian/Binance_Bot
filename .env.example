# --- Telegram (Bot API - бот добавлен админом в канал) ---
FOLLOWUP_CHANNEL_USERNAME=resultrsi
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Твой Telegram USER_ID (опционально)
YOUR_USER_ID=

# --- Binance Square ---
BINANCE_SQUARE_API_KEY=your_binance_square_api_key_here

# --- Groq (генерация текста и зрение, бесплатно) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Расписание трёх форматов постов ---
MIN_POST_INTERVAL_HOURS=4
OPINION_INTERVAL_HOURS=48
ARTICLE_INTERVAL_HOURS=168

POLL_INTERVAL_SECONDS=60

# --- Трекинг результатов сигналов (outcome_tracker.py) ---
# Через сколько часов после публикации сигнал закрывается как "timeout",
# если цена не дошла ни до тейка, ни до стопа.
OUTCOME_MAX_TRACK_HOURS=48

# Если currency-формат не публиковался дольше этого числа часов - алерт
# в личку Telegram (нужен YOUR_USER_ID выше).
DEAD_MANS_SWITCH_HOURS=24
